<div class="my-3">
  <%= form.label :user, class: "app-form-label" %>
  <%= user_order.user&.email %>
</div>

<div class="my-3">
  <%= form.label :created_at, class: "app-form-label" %>
  <%= user_order.created_at.strftime("%Y-%m-%d %H:%M") %>
</div>

<div class="my-3">
  <%= form.label :discarded_at, class: "app-form-label" %>
  <%= user_order.discarded_at ? user_order.discarded_at.strftime("%Y-%m-%d %H:%M") : 'none' %>
</div>

