<div class="mb-40">

  <div class="flex items-center justify-center">
    <div class="grid md:grid-cols-3 gap-8 p-10 max-w-6xl">
      <div class="app-card">
        <h2 class="text-xl font-bold mb-3">厳選された商品</h2>
        <p class="text-gray-600">
          品質とデザインにこだわり、国内外から選び抜いたアイテムを取り揃えています。
        </p>
        <button class="mt-4 app-btn-indigo"> 商品を見る </button>
      </div>

      <div class="app-card">
        <h2 class="text-xl font-bold mb-3">スムーズなお買い物</h2>
        <p class="text-gray-600">
          シンプルで使いやすい設計で、ストレスなくお買い物をお楽しみいただけます。
        </p>
        <button class="mt-4 app-btn-primary"> 詳しく見る </button>
      </div>

      <div class="app-card">
        <h2 class="text-xl font-bold mb-3">安心の配送サービス</h2>
        <p class="text-gray-600">
          ご注文いただいた商品を、迅速かつ丁寧にお届けします。
        </p>
        <button class="mt-4 app-btn-purple"> 配送について </button>
      </div>
    </div>
  </div>

  <div class="mt-20">
    <%= render 'shared/ui/slide_show', list: [
      asset_path('sample.svg'),
      asset_path('sample.svg'),
      asset_path('sample.svg')
    ] %>
  </div>

  <div class="mt-20">
    <%= render 'shared/ui/slide_show', list: [
      asset_path('sample.svg'),
      asset_path('sample.svg'),
      asset_path('sample.svg')
    ] %>
  </div>
  
</div>